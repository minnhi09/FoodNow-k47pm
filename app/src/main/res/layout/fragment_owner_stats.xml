<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thống kê &amp; Doanh thu"
                android:textColor="#212121"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_stats_store_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#757575"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Time filter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tab_today"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_tab_selected"
                android:gravity="center"
                android:text="Hôm nay"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tab_week"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_tab_unselected"
                android:gravity="center"
                android:text="Tuần này"
                android:textColor="#FF6B35"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tab_month"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_unselected"
                android:gravity="center"
                android:text="Tháng này"
                android:textColor="#FF6B35"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- 4 stat cards -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="true">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Doanh thu" android:textColor="#757575" android:textSize="12sp" />
                    <TextView android:id="@+id/tv_stat_revenue" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:text="0đ" android:textColor="#212121" android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView android:id="@+id/tv_stat_revenue_change" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="2dp"
                        android:text="" android:textSize="11sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Đơn hàng" android:textColor="#757575" android:textSize="12sp" />
                    <TextView android:id="@+id/tv_stat_orders" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:text="0" android:textColor="#212121" android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp" android:text="đơn hoàn thành"
                        android:textColor="#9E9E9E" android:textSize="11sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Đánh giá TB" android:textColor="#757575" android:textSize="12sp" />
                    <TextView android:id="@+id/tv_stat_rating" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:text="0.0 ⭐" android:textColor="#FF9800" android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp" android:text="điểm"
                        android:textColor="#9E9E9E" android:textSize="11sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Khách hàng" android:textColor="#757575" android:textSize="12sp" />
                    <TextView android:id="@+id/tv_stat_customers" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:text="0" android:textColor="#212121" android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp" android:text="lượt đặt"
                        android:textColor="#9E9E9E" android:textSize="11sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <!-- Top món bán chạy -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Top món bán chạy"
                    android:textColor="#212121"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="6dp">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content"
                        android:text="#" android:textColor="#9E9E9E" android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Tên món"
                        android:textColor="#9E9E9E" android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                        android:text="Đã bán" android:textColor="#9E9E9E" android:textSize="12sp"
                        android:textStyle="bold" android:gravity="end" />
                    <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                        android:text="Doanh thu" android:textColor="#9E9E9E" android:textSize="12sp"
                        android:textStyle="bold" android:gravity="end" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F0F0F0" android:layout_marginBottom="6dp" />

                <!-- Top foods list — thêm động từ Fragment -->
                <LinearLayout
                    android:id="@+id/container_top_foods"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tv_no_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="Chưa có dữ liệu trong khoảng thời gian này"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>

