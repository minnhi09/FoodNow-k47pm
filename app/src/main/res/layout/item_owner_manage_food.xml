<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Hàng thông tin: ảnh + chi tiết -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Ảnh món ăn với Hot badge overlay -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <ImageView
                    android:id="@+id/img_food"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_image_rounded"
                    android:scaleType="centerCrop" />

                <!-- "Hot" badge overlay -->
                <TextView
                    android:id="@+id/tv_hot_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_hot_badge"
                    android:paddingStart="6dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="6dp"
                    android:paddingBottom="2dp"
                    android:text="Hot"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- Chi tiết món ăn -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Tên + Danh mục -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_food_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Tên món"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_food_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Danh mục"
                        android:textColor="#FF6B35"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Giá -->
                <TextView
                    android:id="@+id/tv_food_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="0đ"
                    android:textColor="#FF6B35"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Mô tả -->
                <TextView
                    android:id="@+id/tv_food_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text=""
                    android:textColor="#9E9E9E"
                    android:textSize="12sp" />

                <!-- Đã bán -->
                <TextView
                    android:id="@+id/tv_food_sold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Đã bán: 0"
                    android:textColor="#BDBDBD"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Hàng action buttons (3 nút ngang) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <!-- Toggle trạng thái: Đang bán / Ẩn món -->
            <TextView
                android:id="@+id/tv_available"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="2"
                android:background="@drawable/bg_food_action_green"
                android:gravity="center"
                android:text="👁 Đang bán"
                android:textColor="#388E3C"
                android:textSize="12sp" />

            <!-- Sửa -->
            <TextView
                android:id="@+id/btn_edit"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="2"
                android:background="@drawable/bg_food_action_orange"
                android:gravity="center"
                android:text="✏ Sửa"
                android:textColor="#FF6B35"
                android:textSize="12sp" />

            <!-- Xóa -->
            <TextView
                android:id="@+id/btn_delete"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_food_action_pink"
                android:gravity="center"
                android:text="🗑"
                android:textColor="#E53935"
                android:textSize="16sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
