<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F0EAE4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Order ID and Status -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#GF2024011901"
                android:textColor="@color/home_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_order_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_toEndOf="@id/tv_order_id"
                android:background="@drawable/bg_home_popular_chip"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Đang giao"
                android:textColor="@color/white"
                android:textSize="11sp" />

        </RelativeLayout>

        <TextView
            android:id="@+id/tv_order_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Hôm nay, 14:30"
            android:textColor="@color/home_text_secondary"
            android:textSize="12sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#F0EAE4" />

        <!-- Store Info and Food Summary -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_order_store"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher"
                app:shapeAppearanceOverlay="@style/RoundedImageView8" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/img_order_store"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_order_store_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phở Hà Nội"
                    android:textColor="@color/home_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_order_item_count_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="2 món • 95.000đ"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_order_items_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Phở Bò Đặc Biệt, Chả Giò"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#F0EAE4" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_action_secondary"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="Theo dõi"
                android:textAllCaps="false"
                android:textColor="@color/home_text_primary"
                app:cornerRadius="12dp"
                app:strokeColor="#F0EAE4" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_action_primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/home_primary_orange"
                android:text="Chi tiết"
                android:textAllCaps="false"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <!-- Delivery Status Footer -->
        <LinearLayout
            android:id="@+id/layout_delivery_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/home_chip_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:id="@+id/iv_footer_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_profile_location"
                app:tint="@color/home_primary_orange" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_delivery_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dự kiến giao hàng"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_delivery_time_remain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Còn khoảng 15 phút"
                    android:textColor="@color/home_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
