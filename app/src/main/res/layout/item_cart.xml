<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F0EAE4">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/img_cart_food"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            app:shapeAppearanceOverlay="@style/RoundedImageView8" />

        <LinearLayout
            android:id="@+id/layout_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/img_cart_food"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_cart_food_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Phở Bò Đặc Biệt"
                android:textColor="@color/home_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_cart_store_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Phở Hà Nội"
                android:textColor="@color/home_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_cart_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/home_chip_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Ghi chú: Không hành"
                android:textColor="#D46E1F"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

        <ImageView
            android:id="@+id/btn_remove"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="2dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/home_text_secondary" />

        <TextView
            android:id="@+id/tv_cart_food_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/layout_info"
            android:layout_alignStart="@id/layout_info"
            android:layout_marginTop="16dp"
            android:text="65.000đ"
            android:textColor="@color/home_primary_orange"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_below="@id/layout_info"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_quantity_control"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp">

            <TextView
                android:id="@+id/btn_minus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="−"
                android:textColor="@color/home_primary_orange"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tv_cart_quantity"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/home_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_plus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/home_primary_orange"
                android:textSize="18sp" />
        </LinearLayout>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
